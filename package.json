{
  "version": "0.0.32",
  "type": "module",
  "name": "@wexample/js-api",
  "scripts": {
    "build": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@wexample/js-helpers": "*"
  },
  "dependencies": {
    "ky": "^1.4.0"
  },
  "repository": "https://github.com/wexample/js-api",
  "files": [
    "src"
  ],
  "sideEffects": false,
  "exports": {
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "src/*"
      ]
    }
  }
}